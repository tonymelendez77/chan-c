# PostgreSQL connection string (async driver for FastAPI)
DATABASE_URL=
# PostgreSQL connection string (sync driver for Alembic migrations)
SYNC_DATABASE_URL=
# Secret key for JWT signing and session security
SECRET_KEY=
# Environment: development, staging, or production
ENVIRONMENT=
# Twilio account SID (from twilio.com/console)
TWILIO_ACCOUNT_SID=
# Twilio auth token
TWILIO_AUTH_TOKEN=
# Twilio phone number in E.164 format (e.g. +15551234567)
TWILIO_PHONE_NUMBER=
# Twilio WhatsApp number (e.g. whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=
# Vapi API key (from dashboard.vapi.ai)
VAPI_API_KEY=
# Vapi phone number ID for outbound calls
VAPI_PHONE_NUMBER_ID=
# Anthropic API key for Claude extraction
ANTHROPIC_API_KEY=
# Confidence threshold for auto-approving extractions (0.0-1.0)
CONFIDENCE_THRESHOLD=0.7
